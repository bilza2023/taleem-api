<%- include("../partials/head",{title:"Ask Question"}) %>

<%- include("../partials/main-nav") %>

<style>

.hero{
  background:linear-gradient(135deg,#1c6fb8,#0f4f8a);
  color:white;
  text-align:center;
  padding:45px 20px 50px 20px;
  margin-bottom:35px;
  box-shadow:0 6px 20px rgba(0,0,0,0.15);
}

.hero h1{
  margin:0;
  font-size:34px;
}

.ask-box{
  max-width:700px;
  margin:auto;
  background:white;
  padding:35px;
  border-radius:10px;
  box-shadow:0 8px 25px rgba(0,0,0,0.12);
}

.ask-box label{
  font-weight:600;
  display:block;
  margin-bottom:6px;
}

.ask-box input,
.ask-box textarea{
  width:100%;
  padding:10px;
  border:1px solid #ccc;
  border-radius:6px;
  font-size:15px;
}

.ask-box textarea{
  resize:vertical;
}

.ask-box button{
  background:#1c6fb8;
  color:white;
  border:none;
  padding:12px 22px;
  border-radius:6px;
  font-size:15px;
  cursor:pointer;
}

.ask-box button:hover{
  background:#15558e;
}

.success{
  background:#d4edda;
  color:#155724;
  padding:12px;
  border-radius:6px;
  margin-bottom:18px;
}

</style>


<header class="hero">
<h1>Ask a Question</h1>
</header>


<div class="wrapper">

<div class="ask-box">

<% if (success) { %>
  <div class="success">
    ✅ Your question has been submitted successfully.
  </div>
<% } %>

<form method="POST" action="/api/questions">

<input type="hidden" name="contentSlug" value="<%= contentSlug %>">
<input type="hidden" name="contentType" value="<%= contentType %>">
<input type="hidden" name="studentId" value="<%= studentId %>">

<label>Lesson</label>
<input type="text" value="<%= contentSlug %>" disabled>

<br><br>

<label>Your Question</label>

<textarea
name="questionText"
rows="6"
placeholder="Write your question clearly..."
required
></textarea>

<br><br>

<button type="submit">
Submit Question
</button>

</form>

</div>

</div>


<%- include("../partials/footer") %>