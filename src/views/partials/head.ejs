<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= title || "Taleem.Help" %></title>

<style>

/* THEME VARIABLES */

:root{

--primary:#1c6fb8;
--accent:#1bb6b2;

--bg:#f5f6f7;
--card:#ffffff;

--text:#222;
--text-soft:#666;
--text-muted:#888;

}

/* BASE */

body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* WRAPPER */

.wrapper{
  max-width:1100px;
  margin:auto;
  padding:35px 20px;
}

/* LINKS */

a{
  color:var(--primary);
  text-decoration:none;
}

a:hover{
  color:var(--accent);
}

/* SIMPLE BUTTON */

.btn{
  background:var(--primary);
  color:white;
  padding:10px 16px;
  border-radius:6px;
  display:inline-block;
}

.btn:hover{
  background:#155a95;
}

</style>

</head>
<body>