<%- include("../partials/head",{title:article.title}) %>
<%- include("../partials/main-nav") %>

<style>

.hero{
  background:linear-gradient(135deg,#1c6fb8,#0f4f8a);
  color:white;
  text-align:center;
  padding:55px 20px 60px 20px;
  margin-bottom:35px;
  box-shadow:0 6px 20px rgba(0,0,0,0.15);
}

.hero h1{
  margin:0;
  font-size:36px;
}

.articleBox{
  max-width:800px;
  margin:auto;
  background:white;
  padding:35px;
  border-radius:10px;
  box-shadow:0 10px 25px rgba(0,0,0,0.12);
  line-height:1.7;
  font-size:16px;
  color:#333;
}

.tags{
  font-size:13px;
  color:#777;
  margin-bottom:18px;
}

.articleBox h1,
.articleBox h2,
.articleBox h3{
  margin-top:24px;
}

.articleBox p{
  margin-bottom:16px;
}

</style>


<header class="hero">
<h1><%= article.title %></h1>
</header>

<div class="wrapper">

<div class="articleBox">

<div class="tags">
Tags: <%= article.tags || "general" %>
</div>

<div class="content">
<%- article.contentHtml %>
</div>

</div>

</div>

<%- include("../partials/footer") %>