<!DOCTYPE html>
<html>
<head>
<title><%= course.title %></title>

<style>

body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:#f5f6f7;
}

.wrapper{
  max-width:1000px;
  margin:auto;
  padding:30px 20px;
}

.courseTitle{
  font-size:28px;
  margin-bottom:30px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
  gap:20px;
}

.card{
  background:white;
  border-radius:8px;
  padding:18px;
  text-decoration:none;
  color:#222;
  box-shadow:0 2px 6px rgba(0,0,0,0.08);
  transition:transform .15s ease;
}

.card:hover{
  transform:translateY(-3px);
}

.chapterNumber{
  font-size:13px;
  color:#888;
  margin-bottom:6px;
}

.chapterTitle{
  font-size:16px;
  font-weight:600;
}

</style>
</head>

<body>

<div class="wrapper">

<div class="courseTitle">
<%= course.title %>
</div>

<div class="grid">

<% course.chapters.forEach(function(ch,index){ %>

<a class="card" href="/chapter?chapter=<%= ch.slug %>">

<div class="chapterNumber">
Chapter <%= index + 1 %>
</div>

<div class="chapterTitle">
<%= ch.title %>
</div>

</a>

<% }) %>

</div>

</div>

</body>
</html>