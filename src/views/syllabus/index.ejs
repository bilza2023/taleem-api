
<%- include("../partials/head",{title:"Syllabus"}) %>
<%- include("../partials/main-nav") %>

<style>

/* HERO */

.hero{
  background:linear-gradient(135deg,#1c6fb8,#0f4f8a);
  color:white;
  text-align:center;
  padding:55px 20px 60px 20px;
  margin-bottom:35px;
  box-shadow:0 6px 20px rgba(0,0,0,0.15);
}

.hero h1{
  margin:0;
  font-size:36px;
}

/* CHAPTER GRID */

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:24px;
  margin-top:35px;
}

/* CARD */

.card{
  background:white;
  border-radius:10px;
  overflow:hidden;
  text-decoration:none;
  color:#222;
  box-shadow:0 10px 25px rgba(0,0,0,0.12);
  transition:all .25s ease;
}

.card:hover{
  transform:translateY(-6px);
  border:2px solid #1bb6b2;
  box-shadow:0 18px 35px rgba(0,0,0,0.18);
}

/* IMAGE */

.thumb{
  height:150px;
  background:#eee;
}

.thumb img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* CARD BODY */

.cardBody{
  padding:16px;
}

.chapterNumber{
  font-size:12px;
  color:#777;
  margin-bottom:4px;
}

.chapterTitle{
  font-size:17px;
  font-weight:600;
  margin-bottom:6px;
}

.chapterDetails{
  font-size:13px;
  color:#555;
  line-height:1.4;
  margin-bottom:12px;
}

.chapterStats{
  font-size:12px;
  color:#777;
  border-top:1px solid #eee;
  padding-top:8px;
}

/* STATS BAR */

.stats-bar{
  display:flex;
  justify-content:space-around;
  align-items:center;
  gap:20px;
  padding:30px 20px;
  margin:20px 0 30px 0;
  background:white;
  border-radius:10px;
  box-shadow:0 8px 20px rgba(0,0,0,0.08);
}

.stat{
  text-align:center;
}

.stat-number{
  font-size:28px;
  font-weight:bold;
  color:#1c6fb8;
}

.stat-label{
  font-size:14px;
  color:#666;
  margin-top:6px;
}

</style>



<header class="hero">
<h1 id="course-title">Loading...</h1>
</header>



<div class="wrapper">

<div class="stats-bar">

<div class="stat">
<div class="stat-number" id="chapters-count">0</div>
<div class="stat-label">Chapters</div>
</div>

<div class="stat">
<div class="stat-number" id="lessons-count">0</div>
<div class="stat-label">Lessons</div>
</div>

<div class="stat">
<div class="stat-number">FBISE</div>
<div class="stat-label">Board</div>
</div>

</div>



<div class="grid" id="chapters-grid"></div>

</div>



<script type="module">

import { loadSyllabus, getSyllabus } from "/js/syllabusObject.js"
// debugger;
async function init(){

  await loadSyllabus()

  const syllabus = getSyllabus()

  const params = new URLSearchParams(window.location.search)
  const courseSlug = params.get("course")

  const course = syllabus.getCourse(courseSlug)

  if(!course){
    document.getElementById("course-title").innerText = "Course not found"
    return
  }

  // title
  document.getElementById("course-title").innerText = course.title

  // stats
  document.getElementById("chapters-count").innerText = course.chapters.length

  const lessons = course.chapters.reduce((sum,c)=>sum + (c.lessons || 0),0)

  document.getElementById("lessons-count").innerText = lessons

  // render chapters
  const grid = document.getElementById("chapters-grid")

  course.chapters.forEach((ch,index)=>{

    const card = `
      <a class="card" href="/class?chapter=${ch.slug}">
        <div class="thumb">
          <img src="/images/${ch.image}" alt="">
        </div>

        <div class="cardBody">

          <div class="chapterNumber">
            Chapter ${index + 1}
          </div>

          <div class="chapterTitle">
            ${ch.title}
          </div>

          <div class="chapterDetails">
            ${ch.details || ""}
          </div>

          <div class="chapterStats">
            Lessons available: ${ch.lessons || 0}
          </div>

        </div>
      </a>
    `

    grid.insertAdjacentHTML("beforeend", card)

  })

}

init()

</script>



<%- include("../partials/footer") %>