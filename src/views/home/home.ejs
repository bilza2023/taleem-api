<!DOCTYPE html>
<html>
<head>
  <title>Taleem</title>

  <style>
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:#111;
      color:white;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:100vh;
    }

    .container{
      max-width:900px;
      width:100%;
      padding:40px 20px;
      text-align:center;
    }

    h1{
      margin-bottom:40px;
      font-size:36px;
    }

    .courses{
      display:flex;
      gap:30px;
      justify-content:center;
      flex-wrap:wrap;
    }

    .course{
      width:320px;
      text-decoration:none;
      color:white;
    }

    .poster{
      width:100%;
      border-radius:8px;
      overflow:hidden;
      box-shadow:0 10px 25px rgba(0,0,0,0.5);
      transition:transform 0.2s;
    }

    .poster img{
      width:100%;
      display:block;
    }

    .course:hover .poster{
      transform:scale(1.03);
    }

    .label{
      margin-top:10px;
      font-size:18px;
      color:#ddd;
    }

    /* Mobile */
    @media (max-width:600px){
      .courses{
        flex-direction:column;
        align-items:center;
      }

      .course{
        width:90%;
      }
    }
  </style>
</head>

<body>

<div class="container">

  <h1>Join Our Online Courses</h1>

  <div class="courses">

    <a class="course" href="/class9">
      <div class="poster">
        <img src="/images/box.webp" alt="Class 9">
      </div>
      <div class="label">Class 9 Mathematics</div>
    </a>

    <a class="course" href="/class10">
      <div class="poster">
        <img src="/images/box.webp" alt="Class 10">
      </div>
      <div class="label">Class 10 Mathematics</div>
    </a>

  </div>

</div>

</body>
</html>