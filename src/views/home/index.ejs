<%- include("../partials/head",{title:"Taleem"}) %>

<%- include("../partials/main-nav") %>

<style>

/* HERO HEADER */

.hero{
  background:linear-gradient(135deg,#1c6fb8,#0f4f8a);
  color:white;
  text-align:center;
  padding:55px 20px 60px 20px;
  margin-bottom:35px;
  box-shadow:0 6px 20px rgba(0,0,0,0.15);
}

.hero h1{
  margin:0;
  font-size:38px;
  letter-spacing:0.5px;
}

/* posters */

.posters{
  display:flex;
  gap:30px;
  margin-bottom:25px;
}

.poster{
  flex:1;
  display:block;
  border-radius:10px;
  overflow:hidden;
  border:3px solid transparent;
  transition:all 0.35s ease;
}

.poster img{
  width:100%;
  display:block;
  transition:transform 0.35s ease;
  box-shadow:0 10px 25px rgba(0,0,0,0.15);
}

/* hover */

.poster:hover{
  transform:translateY(-6px);
  border:3px solid #1bb6b2;
  box-shadow:0 20px 40px rgba(0,0,0,0.25);
  cursor:pointer;
}

.poster:hover img{
  transform:scale(1.04);
}

/* divider */

.poster-divider{
  width:120px;
  height:3px;
  background:linear-gradient(90deg,#1c6fb8,#1bb6b2);
  margin:10px auto 30px auto;
  border-radius:3px;
}

/* stacked on small screens */

@media (max-width:900px){

.posters{
  flex-direction:column;
}

}

/* text section */

.info{
  max-width:800px;
  margin:auto;
  line-height:1.7;
  font-size:16px;
  color:#444;
}

.info p{
  margin-bottom:18px;
}

</style>


<header class="hero">
<h1>Taleem.Help Online Courses</h1>
</header>


<div class="wrapper">

<!-- posters -->

  <div class="posters">

    <% courses.forEach(course => { %>
    
    <a class="poster" href="/syllabus?course=<%= course.slug %>">
    
    <img 
    src="/images/<%= course.slug %>-poster.png"
    onerror="this.onerror=null;this.src='/images/taleem.webp';"
    >
    
    </a>
    
    <% }) %>
    
    </div>


<%- include("../partials/stats") %>


<!-- explanation -->

<div class="info">

<p>
Our online mathematics classes are designed for students studying under the Federal Board.
The lessons focus on clear explanations, visual understanding, and step-by-step problem solving
so that students can build strong mathematical foundations rather than relying on memorization.
</p>

<p>
Each topic is taught using carefully prepared visual material that helps students understand
concepts in algebra, geometry, and other core areas of mathematics. The goal is to make learning
calm, structured, and easy to follow for students who want clarity in their studies.
</p>

<p>
Students can choose their class and begin exploring the chapters immediately.
Every lesson is prepared to support exam preparation while also strengthening
conceptual understanding of mathematics.
</p>

</div>

</div>


<%- include("../partials/footer") %>