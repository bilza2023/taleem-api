<%- include("../partials/head",{title:"My Questions"}) %>

<%- include("../partials/main-nav") %>

<style>

.hero{
  background:linear-gradient(135deg,#1c6fb8,#0f4f8a);
  color:white;
  text-align:center;
  padding:45px 20px 50px 20px;
  margin-bottom:35px;
  box-shadow:0 6px 20px rgba(0,0,0,0.15);
}

.hero h1{
  margin:0;
  font-size:34px;
}

.qa{
  background:white;
  border-radius:8px;
  padding:20px;
  margin-bottom:20px;
  box-shadow:0 6px 18px rgba(0,0,0,0.1);
}

.question{
  font-weight:bold;
  margin-bottom:8px;
}

.answer{
  margin-top:6px;
  color:#333;
}

.links{
  margin-top:10px;
}

.links a{
  margin-right:12px;
  color:#1c6fb8;
  text-decoration:none;
}

.links a:hover{
  text-decoration:underline;
}

.meta{
  margin-top:8px;
  font-size:13px;
  color:#777;
}

.empty{
  text-align:center;
  color:#666;
  margin-top:40px;
}

</style>


<header class="hero">
<h1>My Questions</h1>
</header>


<div class="wrapper">

<div id="questions"></div>

</div>


<script>

async function loadQuestions(){

  const res = await fetch("/api/questions/student");
  const data = await res.json();

  const container = document.getElementById("questions");

  if(!data.questions.length){
    container.innerHTML = `
      <div class="empty">
        <p>You have not asked any questions yet.</p>
      </div>
    `;
    return;
  }

  data.questions.forEach(q => {

    let linksHTML = "";

    if(q.links){

      const links = q.links.split(",");

      links.forEach(l => {

        const [type, slug] = l.split(":");

        linksHTML += `<a href="/${type}/${slug}">${slug}</a>`;

      });

    }

    const date = new Date(q.createdAt).toLocaleDateString();

    const block = `
      <div class="qa">

        <div class="question">
          Question: ${q.questionText}
        </div>

        <div class="answer">
          ${
            q.answerText
            ? "Answer: " + q.answerText
            : "<em>Answer pending</em>"
          }
        </div>

        <div class="links">
          ${linksHTML}
        </div>

        <div class="meta">
          Asked on: ${date}
        </div>

      </div>
    `;

    container.insertAdjacentHTML("beforeend", block);

  });

}

loadQuestions();

</script>


<%- include("../partials/footer") %>