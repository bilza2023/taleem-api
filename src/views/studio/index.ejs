
<!DOCTYPE html>
<html>
<head>
<title>My Questions</title>

<style>

body{
  font-family:Arial, Helvetica, sans-serif;
  max-width:800px;
  margin:auto;
  padding:30px;
}

.qa{
  margin-bottom:35px;
}

.question{
  font-weight:bold;
}

.answer{
  margin-top:8px;
}

.links{
  margin-top:10px;
}

.links a{
  margin-right:10px;
}

hr{
  margin-top:25px;
}

</style>
</head>

<body>

<h1>My Questions</h1>

<div id="questions"></div>

<script>

const studentId = "<%= studentId %>";

async function loadQuestions(){

  const res = await fetch(`/api/questions/student/${studentId}`);

  const data = await res.json();

  const container = document.getElementById("questions");

  if(!data.questions.length){
    container.innerHTML = "<p>You have not asked any questions yet.</p>";
    return;
  }

  data.questions.forEach(q => {

    let linksHTML = "";

    if(q.links){
      const links = q.links.split(",");

      links.forEach(l => {

        const [type, slug] = l.split(":");

        linksHTML += `<a href="/${type}/${slug}">${slug}</a>`;

      });
    }

    const block = `
      <div class="qa">

        <div class="question">
          Question: ${q.questionText}
        </div>

        <div class="answer">
          ${
            q.answerText
            ? "Answer: " + q.answerText
            : "<em>Answer pending</em>"
          }
        </div>

        <div class="links">
          ${linksHTML}
        </div>

      </div>

      <hr>
    `;

    container.insertAdjacentHTML("beforeend", block);

  });

}

loadQuestions();

</script>

</body>
</html>