<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<title>Taleem Class</title>

<link rel="stylesheet" href="/css/taleem-player-app.css">
<link rel="stylesheet" href="/player/player.css">
<link rel="stylesheet" href="/css/answer.css">
<link rel="stylesheet" href="/css/syllabus.css">

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">

<script defer
src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

<script defer
src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>

<style>

:root {
  --backgroundColor: #798ded;
  --primaryColor: #010518;
}

body{
  background:var(--backgroundColor);
  color:var(--primaryColor);
  transition:background 0.25s ease, color 0.25s ease;
}

html, body {
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
}

.page {
  min-height: 100vh;
  overflow-y: auto;
}

#answers-view {
  max-height: 100vh;
  overflow-y: auto;
  padding: 20px;
}

</style>
</head>

<body>

<div id="player-view" data-chapter="<%= chapter %>">

  <div class="page">

    <div class="left">

      <div class="deck-wrapper">
        <div id="app"></div>
      </div>

      <%- include("player-navbar") %>

    </div>

    <%- include("syllabus-panel") %>

  </div>

</div>


<!-- Discussion / FAQ -->

<div id="answers-view">

  <div class="answers-container">

    <div class="answers-header">
      <h2>Discussion / FAQ</h2>

      <!-- JS will inject deck slug -->
      <a href="#" class="ask-question-btn">
        Ask Question
      </a>

    </div>

    <div class="answers-search">
      <input 
        type="text" 
        id="discussion-search" 
        placeholder="Search discussion..."
      >
    </div>

    <div id="discussion-list" class="discussion-list"></div>

  </div>

</div>

<script type="module" src="/js/class-page.js"></script>

</body>
</html>