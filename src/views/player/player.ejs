<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Taleem Player</title>

<link rel="stylesheet" href="/player/taleem-player-app.css">
<link rel="stylesheet" href="/player/player.css">
<link rel="stylesheet" href="/player/themes/default.css">

</head>
<body>

<div id="player-view">
  <div class="page">


<div class="left">
  <div class="deck-wrapper">
    <div id="app"></div>
  </div>

  <%- include("player-navbar") %>
</div>

<%- include("syllabus-panel") %>

  </div>
</div>

<%- include("answer-panel") %>

<script type="module">

import {
  createTaleemPlayer,
  resolveAssetPaths,
  resolveBackground,
  getDeckEndTime,
  createAudioTimer,
  createSilentTimer,
  startLoop
} from "/player/taleem-player-app.js";

function renderSyllabus(syllabus){

const title = document.getElementById("syllabus-title");
const list = document.getElementById("syllabus-list");

if(!syllabus) return;

title.textContent = syllabus.chapter;

syllabus.items.forEach(item => {

  const li = document.createElement("li");

  const link = document.createElement("a");
  link.href = `/player?v=${item.vid}`;
  link.textContent = item.title;

  li.appendChild(link);
  list.appendChild(li);

});

}

function renderDiscussion(discussion){

const container = document.getElementById("discussion-list");

if(!discussion || discussion.length === 0){
  container.innerHTML = "<p>No discussion yet.</p>";
  return;
}

discussion.forEach(item => {

  const block = document.createElement("div");
  block.className = "discussion-item";

  const q = document.createElement("h4");
  q.textContent = item.question;

  const a = document.createElement("p");
  a.textContent = item.answer;

  block.appendChild(q);
  block.appendChild(a);

  container.appendChild(block);

});

}

async function init(){

  // vid passed from Express route
  const vid = "<%= vid %>";

  // fetch presentation package
  const res = await fetch(`/api/presentation/${vid}`);
  const presentation = await res.json();

  const syllabus = presentation.syllabus;
  const discussion = presentation.discussion;

  const imageBase = "/images/";
  const audioBase = "/audio/";

  resolveAssetPaths(presentation, imageBase);
  resolveBackground(presentation, imageBase);

  let timer;

  if(presentation.audio){
    timer = createAudioTimer(`${audioBase}${presentation.audio}`);
  } else {
    timer = createSilentTimer();
  }
///////////////////////////////////////////////////

renderSyllabus(syllabus);
renderDiscussion(discussion);

///////////////////////////////////////////////////
  const player = createTaleemPlayer({
    mount: "#app",
    deck: presentation
  });

  const duration = getDeckEndTime(presentation);

  startLoop({
    player,
    timer,
    duration,
    ui:{
      playBtn: document.getElementById("play-btn"),
      pauseBtn: document.getElementById("pause-btn"),
      stopBtn: document.getElementById("stop-btn"),
      scrub: document.getElementById("scrub"),
      timeEl: document.getElementById("time")
    }
  });

  const sidebar = document.getElementById("sidebar");

  document.getElementById("toggle-sidebar").onclick = () => {
    sidebar.classList.toggle("closed");
  };

  const backBtn = document.getElementById("back-to-player");
  if(backBtn){
    backBtn.onclick = () => {
      answersView.style.display = "none";
      playerView.style.display = "block";
    };
  }

}

init();

</script>

</body>
</html>
