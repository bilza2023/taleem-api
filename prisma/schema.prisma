generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id            String   @id @default(cuid())

  email         String   @unique
  passwordHash  String

  displayName   String
  icon          String   @default("default.png")

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  questions     Question[]
}

model Subscription {
  id          String   @id @default(cuid())

  studentId   String
  classSlug   String

  status      String   @default("active")

  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, classSlug])
}
model Question {
  id           String   @id @default(cuid())

  studentId    String

  contentSlug  String?
  contentType  String?   // deck | article

  questionText String
  answerText   String?
  links        String?

  status       String   @default("new")
  published    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student  @relation(fields: [studentId], references: [id])
}

model Article {
  id          String   @id @default(cuid())

  slug        String   @unique
  title       String

  contentHtml String   

  tags        String?  // comma separated: "algebra,formula,revision"

  published   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}